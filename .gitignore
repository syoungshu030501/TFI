# ============================================================
#  Python
# ============================================================
__pycache__/
*.pyc
*.pyo
*.so
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# ============================================================
#  Secrets / API keys
# ============================================================
.env
.env.*
*.api_key
**/dashscope*.txt
**/openai*.txt

# ============================================================
#  NFS symlinks（这些目录在本机是符号链接，clone 到别处就坏）
# ============================================================
cache
cache_val
checkpoints
models

# data/ 下保留 README.md，但所有真实数据/产物（都是 NFS symlink）忽略
data/raw/*
data/processed/*
data/vlm/caption_api_v3
!data/raw/README.md
!data/processed/README.md

# ============================================================
#  训练/推理产物
# ============================================================
*.pt
*.pth
*.safetensors
*.bin
*.ckpt
wandb/
mlruns/
runs/

# 大块 caption / jsonl 中间产物（>10MB）按需手动 add
*.jsonl
!data/meta/*.jsonl
!logs/data/*.jsonl

# ============================================================
#  日志（只保留有标志意义的 baseline 日志 + .gitkeep 占位）
# ============================================================
logs/**/*.log
logs/**/*.tmp
!logs/seg/segformer_fold0.log
# 但保留 markdown 报告 + 评分结果
!logs/**/*.md
!logs/**/*.json

# ============================================================
#  IDE / OS
# ============================================================
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*.bak
*.tmp
